# ============================================================
#  Aviation Staff Management System — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ── Airline Branding ─────────────────────────────────────────────────
# These values appear throughout the frontend interface.
AIRLINE_NAME=Your Airline Name
AIRLINE_ICAO=XYZ                        # 2-3 letter ICAO airline designator (e.g. UAL, BAW, DLH)
AIRLINE_COUNTRY=Country
AIRLINE_PRIMARY_COLOR=#6366f1           # Hex colour for accents — customise to match your brand

# ── Database ─────────────────────────────────────────────────────────
# SQLite (default, single-file, no extra setup needed):
DATABASE_URL=sqlite:///./fams.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/fams_db

# ── Security ─────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random key before deploying.
# Run: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING_BEFORE_DEPLOYING

# Token expiry in minutes (default 480 = 8-hour shift)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Application ──────────────────────────────────────────────────────
DEBUG=False
APP_VERSION=1.0.0
